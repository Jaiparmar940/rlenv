# Copy to .env and fill in the keys for the providers you want to eval.
# .env is gitignored — never commit real keys.
#
#   cp .env.example .env
#   python scripts/run_evals.py --models anthropic/claude-sonnet-5,openai/gpt-5
#
# Model ids use Inspect's provider/model form (https://inspect.aisi.org.uk):
#   anthropic/claude-sonnet-5, openai/gpt-5, google/gemini-2.5-pro,
#   grok/grok-4, openrouter/qwen/qwen-2.5-7b-instruct, ...
# Only the providers named in --models need a key.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=

# OpenRouter serves the open-weight 3B-8B tier in the scale curve — the
# weight class that would actually run on a robot. Without this key those
# rows in results/scale_curve.md read NEEDS_API_KEY:
#   openrouter/qwen/qwen-2.5-7b-instruct
#   openrouter/meta-llama/llama-3.1-8b-instruct
#   openrouter/mistralai/ministral-3b-2512
OPENROUTER_API_KEY=
