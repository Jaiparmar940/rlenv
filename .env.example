# Copy to .env and fill in the keys for the providers you want to eval.
# .env is gitignored — never commit real keys.
#
#   cp .env.example .env
#   python scripts/run_evals.py --models anthropic/claude-sonnet-5,openai/gpt-5
#
# Model ids use Inspect's provider/model form (https://inspect.aisi.org.uk):
#   anthropic/claude-sonnet-5, openai/gpt-5, google/gemini-2.5-pro, ...
# Only the providers named in --models need a key.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
